{
  "name": "win-calendar",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "desktop": "cd desktop && npm install && npm run start",
    "desktop:dev": "cd desktop && npm install && npm run dev"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "ai": "^6.0.168",
    "dotenv": "^17.4.2",
    "hono": "^4.12.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
