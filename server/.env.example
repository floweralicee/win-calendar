# Copy to server/.env and fill in. This example file is committed; the real
# .env is never committed (see .gitignore).

# Vercel AI Gateway key (routes to Anthropic Claude and other models).
# The operator's shared key — not per-user.
AI_GATEWAY_API_KEY=

# Resend API key (operator's shared account — every morning email is sent
# from this account). Obtain from https://resend.com/api-keys.
RESEND_API_KEY=

# "From" address on outgoing emails. Must be on a domain verified in the
# operator's Resend account, OR use the sandbox `onboarding@resend.dev`
# (sandbox only delivers to the email that owns the Resend account).
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional server port override (default 8787).
# PORT=8787
